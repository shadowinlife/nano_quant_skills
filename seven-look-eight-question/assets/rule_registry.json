{
  "framework": "高效财务分析框架",
  "methodology": "七看八问",
  "version": "1.0",
  "rules": [
    {
      "rule_id": "look-01",
      "sequence": 1,
      "category": "look",
      "title": "一看盈收与利润质量",
      "status": "implemented",
      "parallel_lane": "core",
      "data_status": "all-fields-present",
      "tables": [
        "fin_income",
        "fin_indicator",
        "fin_cashflow"
      ],
      "derived_metrics": [
        "profit_dedt",
        "grossprofit_margin",
        "netprofit_margin",
        "profit_to_gr",
        "n_cashflow_act",
        "n_income_attr_p",
        "c_pay_acq_const_fiolta",
        "net_profit_cash_ratio",
        "fcf",
        "net_profit_cash_ratio_avg",
        "net_profit_cash_ratio_below_one_years",
        "fcf_positive_years",
        "grossprofit_margin_declining_3y"
      ],
      "missing_data": [],
      "script": "look-01-profit-quality/scripts/look_01_profit_quality.py",
      "test_status": "passed",
      "review_status": "reviewed",
      "notes": "默认分析最近3年，仅取 report_type=1 合并报表，核心关注净现比、FCF 和毛利率连续下滑。"
    },
    {
      "rule_id": "look-02",
      "sequence": 2,
      "category": "look",
      "title": "二看费用成本结构",
      "status": "implemented",
      "parallel_lane": "core",
      "data_status": "all-fields-present-rd-rate-derived",
      "tables": [
        "fin_income",
        "fin_indicator"
      ],
      "derived_metrics": [
        "rdexp_to_gr",
        "sell_exp_yoy",
        "admin_exp_yoy",
        "fin_exp_yoy",
        "rd_exp_yoy"
      ],
      "missing_data": [],
      "script": "look-02-cost-structure/scripts/look_02_cost_structure.py",
      "test_status": "passed",
      "review_status": "reviewed",
      "notes": "核心关注四费率与费用增速/营收增速匹配度，其中研发费用率由 rd_exp / total_revenue 派生。"
    },
    {
      "rule_id": "look-03",
      "sequence": 3,
      "category": "look",
      "title": "三看增长率趋势",
      "status": "implemented",
      "parallel_lane": "core",
      "data_status": "cagr-direct-acquisition-proxy",
      "tables": [
        "fin_income",
        "fin_balance",
        "fin_cashflow"
      ],
      "derived_metrics": [
        "revenue_cagr",
        "n_income_attr_p_cagr",
        "goodwill_to_assets",
        "acquisition_cash_to_revenue",
        "growth_mode_signal"
      ],
      "missing_data": [],
      "script": "look-03-growth-trend/scripts/look_03_growth_trend.py",
      "test_status": "passed",
      "review_status": "reviewed",
      "notes": "核心关注收入 CAGR、归母净利润 CAGR 以及通过商誉和并购现金支出识别的增长模式。"
    },
    {
      "rule_id": "look-04",
      "sequence": 4,
      "category": "look",
      "title": "四看业务构成与市场分布",
      "status": "implemented",
      "parallel_lane": "core",
      "data_status": "sw-peers-available-report-text-human-loop",
      "tables": [
        "stk_info",
        "idx_sw_classify",
        "idx_sw_member_all",
        "idx_sw_l3_peers"
      ],
      "derived_metrics": [
        "peer_candidate_count",
        "business_composition_evidence_count",
        "overseas_sales_evidence_count",
        "customer_concentration_evidence_count"
      ],
      "missing_data": [
        "annual_report_full_text",
        "segment_revenue_mix",
        "regional_sales_split",
        "single_customer_sales"
      ],
      "script": "look-04-business-market-distribution/scripts/look_04_business_market_distribution.py",
      "test_status": "passed",
      "review_status": "reviewed",
      "notes": "结构化画像依赖申万三级同行池；缺少年报全文时转为 human-in-loop，从文本补业务构成、海外销售和客户集中度证据。"
    },
    {
      "rule_id": "look-05",
      "sequence": 5,
      "category": "look",
      "title": "五看资产负债健康度",
